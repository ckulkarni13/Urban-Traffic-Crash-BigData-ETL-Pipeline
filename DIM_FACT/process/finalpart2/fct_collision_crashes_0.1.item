    <elementParameter field="MEMO_SQL" name="QUERY" value="&quot;select collision_id, &#xA;(sum(case when contributing_factor_vehicle_1 is not null then 1 else 0 end)+&#xA;sum(case when contributing_factor_vehicle_2 is not null then 1 else 0 end)+&#xA;sum(case when contributing_factor_vehicle_3 is not null then 1 else 0 end) )as number_of_contributing_factors,&#xA;(sum(case when vehicle_type_code1 is not null then 1 else 0 end)+&#xA;sum(case when vehicle_type_code2 is not null then 1 else 0 end)+&#xA;sum(case when vehicle_type_code_3 is not null then 1 else 0 end)+&#xA;sum(case when vehicle_type_code_4 is not null then 1 else 0 end)+&#xA;sum(case when vehicle_type_code_5 is not null then 1 else 0 end)) as number_of_vehicles_involved&#xA;  from stg_nyc_mv_collisions_BigQuery group by collision_id&quot;"/>
